rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /videos/{userId}/{allPaths=**} {
      // Allow users to upload their own videos if they are authenticated via Custom Token
      allow write: if request.auth != null && request.auth.uid == userId;
      // Allow everyone to read videos
      allow read: if true;
    }
    match /thumbnails/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if true;
    }
  }
}
