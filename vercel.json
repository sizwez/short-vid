{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/firebase-messaging-sw.js",
      "destination": "/firebase-messaging-sw.js"
    },
    {
      "source": "/((?!firebase-messaging-sw.js|vite.svg|pwa-.*).*)",
      "destination": "/"
    }
  ]
}
